generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  matricula Int      @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(STUDENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  authoredCases      Case[]         @relation("TeacherCases")
  assignmentsCreated Assignment[]   @relation("TeacherAssignments")
  assignedCases      AssignedCase[]
  reviews            Review[]
}

model AuthorizedTeacher {
  id        String @id @default(uuid())
  matricula Int    @unique

  firstName String?
  lastName  String?

  createdAt DateTime @default(now())
}

model Assignment {
  id String @id @default(uuid())

  title       String
  description String?

  isPublished Boolean @default(false)

  teacherId String
  teacher   User   @relation("TeacherAssignments", fields: [teacherId], references: [id])

  assignedCases AssignedCase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Case {
  id String @id @default(uuid())

  title   String?
  scenery String
  consult String

  age    Int
  gender Gender

  patientName     String?
  medicalHistory  String[]
  medications     String?
  generalFindings String?

  fc          Int?
  fr          Int?
  ta          String?
  spo2        Int?
  glucose     Int?
  temperature Float?
  glasgow     Int?

  capillaryFiller Float?
  cincinnati      Json?

  area MedicalArea

  isPublished Boolean @default(false)

  teacherId String
  author    User   @relation("TeacherCases", fields: [teacherId], references: [id])

  assignedCases AssignedCase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([title, patientName, teacherId])
}

model AssignedCase {
  id String @id @default(uuid())

  assignmentId String
  studentId    String
  caseId       String

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id])
  case       Case       @relation(fields: [caseId], references: [id])

  submission Submission?

  assignedAt DateTime @default(now())

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([caseId])
  @@index([assignmentId])
}

model Submission {
  id String @id @default(uuid())

  assignedCaseId String @unique
  studentId String

  assignedCase AssignedCase @relation(fields: [assignedCaseId], references: [id], onDelete: Cascade)

  sceneManagement      String?
  sss                  String?
  primaryTest          String?
  sample               String?
  opqrst               String?
  presumptiveDiagnosis String?

  priority         Priority?
  transferDecision Boolean?
  treatmentPlan    String?
  reportPatient    String?

  status SubmissionStatus @default(DRAFT)

  review Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Review {
  id String @id @default(uuid())

  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User   @relation(fields: [teacherId], references: [id])

  sceneManagement     Json
  primaryAssessment   Json
  patientPriority     Json
  vitalSigns          Json
  focusedAssessment   Json
  physicalExamination Json
  anamnesis           Json
  otherInterventions  Json

  totalScore Int
  feedback   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Priority {
  GREEN
  YELLOW
  RED
  BLACK
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum MedicalArea {
  PEDIATRICS
  TRAUMA
  GYNECO_OBSTETRICS
  ADULT_EMERGENCY
}
